{
  "name": "devpulse",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "client": "npm run dev --prefix frontend",
    "server": "npm run dev --prefix backend",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix backend",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:start": "npm run docker:build && npm run docker:up",
    "docker:dev": "docker-compose up -d mongodb backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}